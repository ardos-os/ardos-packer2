{
  "arch": "riscv64",
  "code-model": "medium",
  "cpu": "generic-rv64",
  "crt-static-respected": true,
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128",
  "default-uwtable": true,
  "dynamic-linking": true,
  "env": "",
  "features": "+m,+a,+f,+d,+c,+zicsr,+zifencei",
  "has-rpath": false,
  "has-thread-local": true,
  "linker": "riscv64-linux-ardos-clang",
  "linker-flavor": "gnu-lld-cc",
  "llvm-abiname": "lp64d",
  "llvm-target": "riscv64-linux-ardos",
  "max-atomic-width": 64,
  "metadata": {
    "description": "Ardos OS RISC-V 64",
    "host_tools": false,
    "std": false,
    "tier": 3
  },
  "os": "ardos",
  "position-independent-executables": true,
  "relro-level": "full",
  "target-family": [
    "unix"
  ],
  "target-mcount": "\u0001_mcount",
  "target-pointer-width": 64
}